# NarrateMyWorld environment variables (server / Cloud Functions side).
#
# Production: set with `firebase functions:secrets:set NAME` (Secret Manager).
# Local emulator: copy this file to functions/.secret.local OR functions/.env
# (both gitignored). The Firebase emulator auto-loads either.
#
# This top-level .env.example is kept only as a reference of which keys exist.
# The runtime now reads from functions/.env / functions/.secret.local; a root
# .env is no longer used.

# Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ElevenLabs: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
# A calm, clear voice works best. Default is "Rachel" (21m00Tcm4TlvDq8ikWAM).
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Featherless: https://featherless.ai/
FEATHERLESS_API_KEY=your-featherless-api-key-here

# Optional: override the default Gemini model for scene description / classification.
GEMINI_MODEL=gemini-3-flash-preview

# Optional: override Featherless model IDs per context.
FEATHERLESS_MODEL_TRANSIT=mistralai/Mistral-7B-Instruct-v0.3
FEATHERLESS_MODEL_RETAIL=meta-llama/Meta-Llama-3-8B-Instruct
FEATHERLESS_MODEL_MEDICAL=epfl-llm/meditron-7b
